extends layout

block content
  h1= title 
  - var image_names = ['laptop', 'phone', 'desktop', 'projector', 'wii']
  - for (let i =0; i<3; i++){
      - var rand_val = Math.floor(Math.random() * 5);
        img(src=("/images/" + image_names[rand_val] + ".png"), alt=image_names[rand_val], height="300", width="300")
  - }